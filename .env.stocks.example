# =============================================================================
#  halal-trader — .env (STOCKS-ONLY starter template)
# =============================================================================
#  Copy this file to `.env` and fill in the REQUIRED section. Crypto-side
#  fields are kept at the bottom for completeness (the parity test wants
#  every Settings field documented in both directions) but you can leave
#  them blank — the crypto bot is a separate entry point (`just crypto`)
#  you simply don't invoke.
#
#  See `.env.example` for the canonical reference; this file's only
#  difference is layout and per-section guidance for stocks operators.
# =============================================================================


# ═════════════════════════════════════════════════════════════════════════════
#  REQUIRED — fill these four to trade stocks
# ═════════════════════════════════════════════════════════════════════════════


# ── 1) Alpaca paper-trading keys ─────────────────────────────────────────────
#   Sign up at https://alpaca.markets, then "Paper Trading" → "View API Keys".
#   Paper trading is real-time data + a simulated $100k account; no real money.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_TRADE=true


# ── 2) LLM — pick one provider ───────────────────────────────────────────────
#   The bot drives every decision through an LLM. Three options:
#
#   a) OpenAI (recommended for a first run — gpt-4o-mini is ~$0.15/M input
#      tokens, fast, broadly available)
#         LLM_PROVIDER=openai
#         LLM_MODEL=gpt-4o-mini
#         OPENAI_API_KEY=sk-...
#
#   b) Anthropic
#         LLM_PROVIDER=anthropic
#         LLM_MODEL=claude-sonnet-4-20250514
#         ANTHROPIC_API_KEY=sk-ant-...
#
#   c) Ollama (zero API spend, needs local install + a model pulled)
#         LLM_PROVIDER=ollama
#         LLM_MODEL=qwen2.5:32b
#         OLLAMA_HOST=http://localhost:11434
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Hard cap on cumulative LLM spend per UTC day (USD). 0 disables.
# When tripped, engages the kill-switch — bot refuses new entries.
LLM_DAILY_USD_CAP=0.0


# ── 3) Database ──────────────────────────────────────────────────────────────
#   `just pg-up` brings up Postgres+pgvector on :5433 (bundled docker compose).
#   You can also point this at any existing Postgres 16+ with pgvector.
DATABASE_URL=postgresql+asyncpg://trader:trader-dev-only@localhost:5433/halal_trader
DATA_DIR=data


# ── 4) Dashboard / web API ───────────────────────────────────────────────────
#   `WEB_API_TOKEN` is the shared-secret header gate for any state-changing
#   dashboard endpoint. Empty → dashboard is read-only.
#   Generate one: `openssl rand -hex 32`
WEB_API_TOKEN=
WEB_REQUIRE_CONFIRMATION=true
WEB_AUDIT_RETENTION_DAYS=90


# ═════════════════════════════════════════════════════════════════════════════
#  RECOMMENDED — improves the bot but optional (each degrades silently)
# ═════════════════════════════════════════════════════════════════════════════


# ── Halal screening (Zoya) ───────────────────────────────────────────────────
#   Without a key the bot falls back to a hardcoded list of 10 well-known
#   halal stocks (AAPL, MSFT, NVDA, AVGO, TSM, GOOG, GOOGL, AMZN, META, …).
#   Sandbox keys are free + randomised; production needs a paid plan.
ZOYA_API_KEY=
ZOYA_USE_SANDBOX=true

# Cache cadence. Hard TTL — refuse to refresh more often than this.
HALAL_CACHE_MAX_AGE_HOURS=6
# Soft threshold — fire a mid-cycle refresh past this age.
HALAL_MIDCYCLE_REFRESH_HOURS=4


# ── Catalyst feeds (stock-side) ──────────────────────────────────────────────
#   Each feed adds a block to the LLM prompt with forward-looking signals.
#   All degrade silently when blank.

# St. Louis Fed — macro release calendar (CPI, FOMC, NFP, GDP). The cycle
# shrinks position size in the 4h window before each high-impact release.
# Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Finnhub.io — per-symbol stocks news (60 req/min free tier). Replaces
# the Yahoo search backend which started 429-ing on 2026-05-21. Empty
# falls back to Yahoo with its existing circuit breaker.
# Free key: https://finnhub.io/register
FINNHUB_API_KEY=

# SEC EDGAR 8-K material-event stream. No API key, but SEC requires every
# request carry a User-Agent with real contact info per their automated-
# access policy. Format: "Your Name (you@example.com)".
EDGAR_USER_AGENT=


# ── Operator notifications ───────────────────────────────────────────────────
#   Telegram is the most useful — fires on fills, errors, daily summaries.

# Telegram: @BotFather → /newbot. chat_id: message the bot, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ═════════════════════════════════════════════════════════════════════════════
#  Stocks — trading parameters (defaults work; tune to taste)
# ═════════════════════════════════════════════════════════════════════════════


TRADING_INTERVAL_MINUTES=15
DAILY_RETURN_TARGET=0.01
MAX_POSITION_PCT=0.20
DAILY_LOSS_LIMIT=0.02
MAX_SIMULTANEOUS_POSITIONS=5

# Position monitor — polls SL/TP between cycles.
MONITOR_INTERVAL_SECONDS=30.0
# Trailing stop. Activation = % profit before the stop starts ratcheting.
TRAILING_STOP_ACTIVATION_PCT=0.005
TRAILING_STOP_DISTANCE_PCT=0.005

# Portfolio risk
MAX_PORTFOLIO_HEAT_PCT=0.05
MAX_DRAWDOWN_PCT=0.08
HIGH_CORRELATION_THRESHOLD=0.7
CORRELATION_REDUCTION_FACTOR=0.5
ATR_BASELINE=0.02

# News-momentum reactor — hard ceiling on classifier API calls per UTC day.
# Default 250 leaves headroom for an active news day; 0 disables the cap.
# Added after the 2026-05-22 incident where a single OpenAI quota exhaustion
# led to 3,736 wasted 429 calls in ~9.5h with no backstop.
REACTOR_DAILY_CLASSIFY_CAP=250

# News-momentum reactor — entry execution ("fast in"). When enabled, a
# high-confidence scored catalyst places a real paper BUY (gated on
# news+price-up confluence) instead of just logging. Set false for
# observation-only. Sizing is a fraction of MAX_POSITION_PCT (0.5 = half),
# and the price-confirmation gate requires the stock to be up at least
# REACTOR_ENTRY_MIN_INTRADAY_CHANGE_PCT on the session before entering.
REACTOR_ENTRIES_ENABLED=true
REACTOR_ENTRY_SIZE_FRACTION=0.5
REACTOR_ENTRY_MIN_INTRADAY_CHANGE_PCT=0.002

# Slow-out: reactor positions are locked from LLM exits and rely on the
# position monitor's WIDE trailing stop (~8%) as their main exit — lets a
# winner run through normal volatility, exits only on a structural break.
# This doubles as the initial hard-stop distance set at entry.
REACTOR_TRAILING_STOP_DISTANCE_PCT=0.08
# Hold reactor positions overnight (exempt from the EOD flatten) so winners
# run across days. Set false to flatten them at EOD like everything else.
REACTOR_HOLD_OVERNIGHT=true

# Slow-out trend-break exit: close a WINNING reactor position when its price
# closes below an SMA of recent bars (structural reversal) — locks in gains
# instead of giving the full ~8% back to the trailing stop. Period + bar
# timeframe are the SMA inputs.
TREND_BREAK_ENABLED=true
TREND_BREAK_MA_PERIOD=20
TREND_BREAK_TIMEFRAME=1Hour

# Reason-agnostic re-entry cooldown: refuse a BUY for any symbol closed within
# this window. Raised 30 → 60 on 2026-06-17 after observing round-trip churn
# (sold INTU then re-bought it 30 min later). 60 min = 4 cycles. 0 disables.
RECENT_CLOSE_COOLDOWN_MINUTES=60

# Falling-knife guard: a position closed by the monitor's STOP-LOSS gets a
# longer re-entry block than the reason-agnostic recent-close cooldown — don't
# re-buy a downtrending stock each time the recent-close cooldown elapses. 0 disables.
STOP_LOSS_REENTRY_COOLDOWN_MINUTES=120

# Stocks-side agentic mode — LLM can call tools (query_rag,
# query_regime_memory) before submitting decisions. Off by default; opt in
# once you have replay snapshots accumulated (the tools query against them).
AGENTIC_ENABLED=false
AGENTIC_MAX_TURNS=5
AGENTIC_MAX_SECONDS=30.0


# ═════════════════════════════════════════════════════════════════════════════
#  LLM — advanced (defaults work for a first run)
# ═════════════════════════════════════════════════════════════════════════════


# Ordered fallback list, e.g. ["openai","anthropic"]. Empty = no fallbacks.
LLM_FALLBACK_PROVIDERS=[]
OLLAMA_FALLBACK_MODEL=
OPENAI_FALLBACK_MODEL=gpt-4o-mini
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514

# Extra critic call per cycle; downsizes/skips buys that lose the argument.
LLM_ADVERSARIAL_ENABLED=false
# Extra ensemble variants beyond the primary call. 0 disables.
LLM_ENSEMBLE_SIZE=0
# Frozen-prompt shadow strategy running in parallel; tracks divergence.
LLM_SHADOW_ENABLED=false
LLM_SHADOW_STARTING_CASH=1000.0


# ═════════════════════════════════════════════════════════════════════════════
#  ML models (requires `uv sync --extra ml`)
# ═════════════════════════════════════════════════════════════════════════════


ML_ENABLED=false
# Device for the torch backend: cpu | cuda | mps
ML_DEVICE=cpu
ML_MODELS_DIR=models


# ═════════════════════════════════════════════════════════════════════════════
#  Live-mode safeguards — only consulted when ALPACA_PAPER_TRADE=false
# ═════════════════════════════════════════════════════════════════════════════
#  Leave the confirmation blank to keep yourself on paper. To go live you'd
#  set: LIVE_MODE_CONFIRMATION=I-UNDERSTAND-REAL-MONEY-YYYY-MM-DD (today's
#  UTC date) AND flip ALPACA_PAPER_TRADE=false. The bot refuses to start
#  in live mode without a current confirmation.

LIVE_MODE_CONFIRMATION=
LIVE_MODE_MAX_ACCOUNT_BALANCE_USD=500.0
LIVE_MODE_MAX_SINGLE_ORDER_USD=100.0
LIVE_MODE_MAX_DAILY_LOSS_PCT=0.02


# ═════════════════════════════════════════════════════════════════════════════
#  Logging
# ═════════════════════════════════════════════════════════════════════════════


LOG_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ═════════════════════════════════════════════════════════════════════════════
#  Sentiment cadence (read by both bots; stocks side uses it for the Yahoo
#  Finance news pull — see below)
# ═════════════════════════════════════════════════════════════════════════════


SENTIMENT_UPDATE_INTERVAL_SECONDS=300


# ═════════════════════════════════════════════════════════════════════════════
#  Reddit sentiment — optional for stocks (mention-velocity surge signal)
# ═════════════════════════════════════════════════════════════════════════════
#  The Reddit OAuth path is shared between markets. For stocks the signal
#  is noisier than crypto (r/wallstreetbets is more meme than fundamentals)
#  so you can skip safely.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=


# ═════════════════════════════════════════════════════════════════════════════
#  NOT USED in stocks-only mode — leave blank
# ═════════════════════════════════════════════════════════════════════════════
#  Documented for completeness (the parity test wants every Settings field
#  represented), but none of these are consulted when you run `just stocks`.


# ── Crypto exchange ──────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true


# ── Crypto-side feeds ────────────────────────────────────────────────────────
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
CRYPTOPANIC_API_KEY=


# ── Crypto — trading parameters ──────────────────────────────────────────────
CRYPTO_TRADING_INTERVAL_SECONDS=60
CRYPTO_PAIRS=["BTCUSDT","ETHUSDT","SOLUSDT","ADAUSDT"]
CRYPTO_MAX_POSITION_PCT=0.25
CRYPTO_DAILY_LOSS_LIMIT=0.03
CRYPTO_DAILY_RETURN_TARGET=0.01
CRYPTO_MAX_SIMULTANEOUS_POSITIONS=4
CRYPTO_MIN_MARKET_CAP=1000000000
CRYPTO_MAX_PAIRS_PER_CYCLE=10

# Portfolio risk
CRYPTO_MAX_PORTFOLIO_HEAT_PCT=0.05
CRYPTO_MAX_DRAWDOWN_PCT=0.08
CRYPTO_HIGH_CORRELATION_THRESHOLD=0.7
CRYPTO_CORRELATION_REDUCTION_FACTOR=0.5
CRYPTO_ATR_BASELINE=0.02

# Flat-market skip
CRYPTO_FLAT_PRICE_THRESHOLD=0.03
CRYPTO_FLAT_RSI_LOWER=40.0
CRYPTO_FLAT_RSI_UPPER=60.0
CRYPTO_FLAT_VOL_THRESHOLD=1.2
CRYPTO_MAX_CONSECUTIVE_FLAT_SKIPS=5

# Trailing stop / monitor
CRYPTO_TRAILING_STOP_ACTIVATION_PCT=0.005
CRYPTO_TRAILING_STOP_DISTANCE_PCT=0.003
CRYPTO_MONITOR_INTERVAL=2.0

# Per-pair circuit breaker
CRYPTO_CIRCUIT_BREAKER_THRESHOLD=5
CRYPTO_CIRCUIT_BREAKER_WINDOW=600
CRYPTO_CIRCUIT_BREAKER_COOLDOWN=1800

# LLM circuit breaker
CRYPTO_LLM_FAILURE_THRESHOLD=5
CRYPTO_LLM_COOLDOWN_SECONDS=600

# Agentic mode
CRYPTO_AGENTIC_ENABLED=false
CRYPTO_AGENTIC_MAX_TURNS=5
CRYPTO_AGENTIC_MAX_SECONDS=30

# Nightly prompt-evolution GA
CRYPTO_PROMPT_EVO_GENERATIONS=8
CRYPTO_PROMPT_EVO_POPULATION=12
CRYPTO_PROMPT_EVO_SNAPSHOTS=200


# ── Slack / Discord notifiers (optional; Telegram above is enough) ───────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=halal-trader
