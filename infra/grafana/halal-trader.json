{
  "annotations": {"list": []},
  "description": "Halal Trader bot — cycle latency, LLM cost, risk state.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "title": "Halal Trader",
  "uid": "halal-trader",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bot running",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "halal_trader_bot_running", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "down", "color": "red"}, "1": {"text": "running", "color": "green"}}}]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Drawdown % (max across markets)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(halal_trader_drawdown_pct) * 100", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Daily LLM spend ($)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "halal_trader_llm_cost_today_usd", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD"}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Open positions",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(halal_trader_open_positions)", "refId": "A"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cycle stage p50 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (stage, le) (rate(halal_trader_stage_latency_ms_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cycle stage p95 (ms)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(halal_trader_stage_latency_ms_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LLM call p50 (ms) by provider",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (provider, le) (rate(halal_trader_llm_call_ms_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{provider}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Broker call error rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (broker, method) (rate(halal_trader_broker_call_ms_count{error=\"1\"}[5m])) / sum by (broker, method) (rate(halal_trader_broker_call_ms_count[5m]))",
          "refId": "A",
          "legendFormat": "{{broker}} / {{method}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Open positions by asset",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "halal_trader_open_positions",
          "refId": "A",
          "legendFormat": "{{asset_class}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Portfolio heat (per market)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "halal_trader_portfolio_heat_pct * 100",
          "refId": "A",
          "legendFormat": "{{market}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent"}}
    }
  ]
}
