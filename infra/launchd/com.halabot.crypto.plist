<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.halabot.crypto</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/caffeinate</string>
        <string>-dimsu</string>
        <string>/Users/nourataha/.local/bin/uv</string>
        <string>run</string>
        <string>halal-trader</string>
        <string>crypto</string>
        <string>start</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/nourataha/lab/halabot</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/nourataha/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
