<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.halabot.watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/nourataha/.local/bin/uv</string>
        <string>run</string>
        <string>halal-trader</string>
        <string>watchdog</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/nourataha/lab/halabot</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/nourataha/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/nourataha</string>
    </dict>

    <key>StartInterval</key>
    <integer>180</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/nourataha/lab/halabot/logs/launchd-watchdog.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/nourataha/lab/halabot/logs/launchd-watchdog.err.log</string>
</dict>
</plist>
