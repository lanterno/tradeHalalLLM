# =============================================================================
#  halal-trader — .env
# =============================================================================
#  Copy this file to `.env` and fill in the values. Anything left blank uses
#  the default from src/halal_trader/config.py. The bot refuses to start in
#  live mode without LIVE_MODE_CONFIRMATION set to today's date.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  REQUIRED — at least one broker + one LLM. Stocks and crypto bots run
#  independently, so you can fill either pair or both.
# ─────────────────────────────────────────────────────────────────────────────

# Alpaca (stocks). Paper keys: https://alpaca.markets → Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER_TRADE=true

# Binance (crypto). Testnet keys: https://testnet.binance.vision (GitHub login)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# LLM: GLM-5.2 over an OpenAI-compatible endpoint. Default is OpenRouter
# (multi-host routing for the same MIT weights — the outage-resilient
# choice). Get a key at https://openrouter.ai/keys. For Z.ai direct use
# GLM_BASE_URL=https://api.z.ai/api/paas/v4 and LLM_MODEL=glm-5.2.
GLM_API_KEY=
GLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=z-ai/glm-5.2
# Hard cap on cumulative LLM spend per UTC day, in USD. 0 disables.
# When tripped, engages the kill-switch — both bots refuse new entries.
LLM_DAILY_USD_CAP=0.0


# ─────────────────────────────────────────────────────────────────────────────
#  Database — Postgres + pgvector
# ─────────────────────────────────────────────────────────────────────────────
#  `just pg-up` brings up the bundled container on :5433. The +asyncpg driver
#  is required; Alembic + admin paths derive +psycopg from this URL.
DATABASE_URL=postgresql+asyncpg://trader:trader-dev-only@localhost:5433/halal_trader
DATA_DIR=data


# ─────────────────────────────────────────────────────────────────────────────
#  Dashboard / web API
# ─────────────────────────────────────────────────────────────────────────────
#  Shared secret required on the X-Trader-Token header for any mutation
#  endpoint. Empty → read-only mode. Generate with `openssl rand -hex 32`.
WEB_API_TOKEN=
#  Whether destructive ops require X-Trader-Confirm: true. Leave on.
WEB_REQUIRE_CONFIRMATION=true
#  Days to keep web_actions audit rows; daily-end hook prunes older. 0 = off.
WEB_AUDIT_RETENTION_DAYS=90


# ─────────────────────────────────────────────────────────────────────────────
#  Halal screening
# ─────────────────────────────────────────────────────────────────────────────

# Zoya (stocks). Sandbox is free + randomised; production needs a paid plan.
ZOYA_API_KEY=
ZOYA_USE_SANDBOX=true

# CoinGecko (crypto). Empty uses the free public tier.
COINGECKO_API_KEY=

# Cache cadence. Hard TTL — refuse to refresh more often than this.
HALAL_CACHE_MAX_AGE_HOURS=6
# Soft threshold — fire a mid-cycle refresh past this age.
HALAL_MIDCYCLE_REFRESH_HOURS=4


# ─────────────────────────────────────────────────────────────────────────────
#  Catalyst & sentiment feeds (all optional, all degrade silently if blank)
# ─────────────────────────────────────────────────────────────────────────────

# St. Louis Fed — drives FOMC/CPI/NFP/GDP calendar.
# Free key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Finnhub.io — stocks news (60 req/min free tier). Replaces the Yahoo
# search backend which started 429-ing on 2026-05-21. Empty falls
# back to Yahoo. Free key: https://finnhub.io/register
FINNHUB_API_KEY=

# SEC EDGAR 8-K stream — no key, but SEC requires a User-Agent with real
# contact info. Format: "Your Name (you@example.com)".
EDGAR_USER_AGENT=

# Etherscan — on-chain whale transfers. Free key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Reddit — sentiment scraper. https://reddit.com/prefs/apps (script app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# CryptoPanic — crypto news reactor (high-impact events preempt the cycle).
# Free key: https://cryptopanic.com/developers/api
CRYPTOPANIC_API_KEY=

SENTIMENT_UPDATE_INTERVAL_SECONDS=300


# ─────────────────────────────────────────────────────────────────────────────
#  Operator notifications (all optional)
# ─────────────────────────────────────────────────────────────────────────────

# Telegram. Talk to @BotFather → /newbot. Get chat_id by messaging the bot
# then hitting https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack incoming webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Discord channel webhook: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=halal-trader


# ─────────────────────────────────────────────────────────────────────────────
#  Stocks — trading parameters
# ─────────────────────────────────────────────────────────────────────────────
TRADING_INTERVAL_MINUTES=15
DAILY_RETURN_TARGET=0.01
MAX_POSITION_PCT=0.20
DAILY_LOSS_LIMIT=0.02
MAX_SIMULTANEOUS_POSITIONS=5

# Position monitor — polls SL/TP between cycles.
MONITOR_INTERVAL_SECONDS=30.0
# Trailing stop. Activation = % profit before the stop starts ratcheting.
# Comment out to disable trailing stops.
TRAILING_STOP_ACTIVATION_PCT=0.005
TRAILING_STOP_DISTANCE_PCT=0.005

# Portfolio risk
MAX_PORTFOLIO_HEAT_PCT=0.05
MAX_DRAWDOWN_PCT=0.08
HIGH_CORRELATION_THRESHOLD=0.7
CORRELATION_REDUCTION_FACTOR=0.5
ATR_BASELINE=0.02

# News-momentum reactor — hard ceiling on classifier API calls per UTC day.
# Pure cost backstop; 0 disables the cap. Raised 250 -> 1500 on 2026-06-09
# once dedup stopped re-scoring duplicates: a full day is ~700-1000 DISTINCT
# headlines, so 250 silently starved the reactor. Quota-exhaustion call-spam
# is now handled by the classifier's half-open quota breaker, not this cap.
REACTOR_DAILY_CLASSIFY_CAP=1500

# Reactor headline classifier: "llm" (GLM-5.2, default) or "finbert"
# (local ProsusAI/finbert — free, no API dependency, resilient to LLM outages).
HEADLINE_CLASSIFIER=llm

# News-momentum reactor — entry execution ("fast in"). When enabled, a
# high-confidence scored catalyst places a real paper BUY (gated on
# news+price-up confluence) instead of just logging. Set false for
# observation-only. Sizing is a fraction of MAX_POSITION_PCT (0.5 = half),
# and the price-confirmation gate requires the stock to be up at least
# REACTOR_ENTRY_MIN_INTRADAY_CHANGE_PCT on the session before entering.
REACTOR_ENTRIES_ENABLED=true
REACTOR_ENTRY_SIZE_FRACTION=0.5
REACTOR_ENTRY_MIN_INTRADAY_CHANGE_PCT=0.002

# Slow-out: reactor positions are locked from LLM exits and rely on the
# position monitor's WIDE trailing stop (~8%) as their main exit — lets a
# winner run through normal volatility, exits only on a structural break.
# This doubles as the initial hard-stop distance set at entry.
REACTOR_TRAILING_STOP_DISTANCE_PCT=0.08
# Hold reactor positions overnight (exempt from the EOD flatten) so winners
# run across days. Set false to flatten them at EOD like everything else.
REACTOR_HOLD_OVERNIGHT=true

# Slow-out trend-break exit: close a WINNING reactor position when its price
# closes below an SMA of recent bars (structural reversal) — locks in gains
# instead of giving the full ~8% back to the trailing stop. Period + bar
# timeframe are the SMA inputs.
TREND_BREAK_ENABLED=true
TREND_BREAK_MA_PERIOD=20
TREND_BREAK_TIMEFRAME=1Hour

# Reason-agnostic re-entry cooldown: refuse a BUY for any symbol closed within
# this window. Raised 30 → 60 on 2026-06-17 after observing round-trip churn
# (sold INTU then re-bought it 30 min later). 60 min = 4 cycles. 0 disables.
RECENT_CLOSE_COOLDOWN_MINUTES=60

# Falling-knife guard: a position closed by the monitor's STOP-LOSS gets a
# longer re-entry block than the reason-agnostic recent-close cooldown — don't
# re-buy a downtrending stock each time the recent-close cooldown elapses. 0 disables.
STOP_LOSS_REENTRY_COOLDOWN_MINUTES=120

# Stocks-side agentic mode — bounded tool-calling loop. Off by default.
AGENTIC_ENABLED=false
AGENTIC_MAX_TURNS=5
AGENTIC_MAX_SECONDS=30.0


# ─────────────────────────────────────────────────────────────────────────────
#  Crypto — trading parameters
# ─────────────────────────────────────────────────────────────────────────────
CRYPTO_TRADING_INTERVAL_SECONDS=60
CRYPTO_PAIRS=["BTCUSDT","ETHUSDT","SOLUSDT","ADAUSDT"]
CRYPTO_MAX_POSITION_PCT=0.25
CRYPTO_DAILY_LOSS_LIMIT=0.03
CRYPTO_DAILY_RETURN_TARGET=0.01
CRYPTO_MAX_SIMULTANEOUS_POSITIONS=4
CRYPTO_MIN_MARKET_CAP=1000000000
CRYPTO_MAX_PAIRS_PER_CYCLE=10

# Portfolio risk
CRYPTO_MAX_PORTFOLIO_HEAT_PCT=0.05
CRYPTO_MAX_DRAWDOWN_PCT=0.08
CRYPTO_HIGH_CORRELATION_THRESHOLD=0.7
CRYPTO_CORRELATION_REDUCTION_FACTOR=0.5
CRYPTO_ATR_BASELINE=0.02

# Flat-market skip — heuristic that avoids LLM spend in dead markets.
CRYPTO_FLAT_PRICE_THRESHOLD=0.03
CRYPTO_FLAT_RSI_LOWER=40.0
CRYPTO_FLAT_RSI_UPPER=60.0
CRYPTO_FLAT_VOL_THRESHOLD=1.2
CRYPTO_MAX_CONSECUTIVE_FLAT_SKIPS=5

# Trailing stop / monitor
CRYPTO_TRAILING_STOP_ACTIVATION_PCT=0.005
CRYPTO_TRAILING_STOP_DISTANCE_PCT=0.003
CRYPTO_MONITOR_INTERVAL=2.0

# Per-pair circuit breaker (unexpected errors only; -1013/-2010/-1003 excluded)
CRYPTO_CIRCUIT_BREAKER_THRESHOLD=5
CRYPTO_CIRCUIT_BREAKER_WINDOW=600
CRYPTO_CIRCUIT_BREAKER_COOLDOWN=1800

# LLM circuit breaker
CRYPTO_LLM_FAILURE_THRESHOLD=5
CRYPTO_LLM_COOLDOWN_SECONDS=600

# Agentic mode — LLM can call tools mid-cycle (bounded). Off by default.
CRYPTO_AGENTIC_ENABLED=false
CRYPTO_AGENTIC_MAX_TURNS=5
CRYPTO_AGENTIC_MAX_SECONDS=30

# Nightly prompt-evolution GA over replay snapshots (Wave F).
CRYPTO_PROMPT_EVO_GENERATIONS=8
CRYPTO_PROMPT_EVO_POPULATION=12
CRYPTO_PROMPT_EVO_SNAPSHOTS=200


# ─────────────────────────────────────────────────────────────────────────────
#  LLM — advanced
# ─────────────────────────────────────────────────────────────────────────────
# Optional SECOND GLM endpoint tried when the primary fails (FallbackLLM
# chain) — same model, different host. E.g. Z.ai direct behind OpenRouter:
#   GLM_FALLBACK_BASE_URL=https://api.z.ai/api/paas/v4
#   GLM_FALLBACK_MODEL=glm-5.2
#   GLM_FALLBACK_API_KEY=<z.ai key>
# All empty = primary endpoint only. Fallback key defaults to GLM_API_KEY.
GLM_FALLBACK_BASE_URL=
GLM_FALLBACK_MODEL=
GLM_FALLBACK_API_KEY=
# Per-call client timeout. Thinking disabled keeps calls well inside this;
# the crypto cycle budget is interval*2 (120s), so 60 leaves headroom.
GLM_TIMEOUT_SECONDS=60
# GLM-5.2 reasons by default upstream — the bot disables it for cycle
# latency and cost. Enable for offline research runs only.
GLM_THINKING=false
# OpenRouter-only: route exclusively to hosts honouring every request
# param (JSON mode + tools). Leave on unless debugging routing.
GLM_REQUIRE_PARAMETERS=true

# Extra critic call per cycle; downsizes/skips buys that lose the argument.
LLM_ADVERSARIAL_ENABLED=false
# Extra ensemble variants beyond the primary call. 0 disables.
LLM_ENSEMBLE_SIZE=0
# Frozen-prompt shadow strategy running in parallel; tracks divergence.
LLM_SHADOW_ENABLED=false
LLM_SHADOW_STARTING_CASH=1000.0


# ─────────────────────────────────────────────────────────────────────────────
#  ML models (requires `uv sync --extra ml`)
# ─────────────────────────────────────────────────────────────────────────────
ML_ENABLED=false
# Device for the torch backend: cpu | cuda | mps
ML_DEVICE=cpu
ML_MODELS_DIR=models


# ─────────────────────────────────────────────────────────────────────────────
#  Live-mode safeguards — only consulted when *_PAPER_TRADE / *_TESTNET = false
# ─────────────────────────────────────────────────────────────────────────────
# Must equal "I-UNDERSTAND-REAL-MONEY-YYYY-MM-DD" with today's UTC date.
LIVE_MODE_CONFIRMATION=
LIVE_MODE_MAX_ACCOUNT_BALANCE_USD=500.0
LIVE_MODE_MAX_SINGLE_ORDER_USD=100.0
LIVE_MODE_MAX_DAILY_LOSS_PCT=0.02


# ─────────────────────────────────────────────────────────────────────────────
#  Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
LOG_DIR=logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
