# ── Alpaca API ──────────────────────────────────────────────
ALPACA_API_KEY=PKECFYVRNPQJ7MNYUASAIYZG7E
ALPACA_SECRET_KEY=6D9zfwHKsMgMRzLwzh1ictbTNdqYCQjZ8Z2J75XJwGJU
# Use paper trading (true) or live (false)
ALPACA_PAPER_TRADE=true

# ── Binance API ─────────────────────────────────────────────
BINANCE_API_KEY=HIDogt7mKVkeabYCCRKC2UWR2E0a9WyIaNmcRDrWSVbfhJSehuo8uXJLCAZcrutI
BINANCE_SECRET_KEY=8Dx8Yk2Yrq2hxLy5jdQyXCTSHh4qrQIToirUyZivT1IDg2B2JuUQoTfxjV2Xa1mU
# Use Binance testnet (true) or production (false)
BINANCE_TESTNET=true

# ── Zoya API (stock halal screening, optional) ──────────────
ZOYA_API_KEY=sandbox-09e9ffa7-b51c-4e58-b691-f70e71b4069a
# Use Zoya sandbox environment (free, randomized data)
ZOYA_USE_SANDBOX=true

# ── CoinGecko API (crypto halal screening, optional) ────────
COINGECKO_API_KEY=

# ── FRED API (St. Louis Fed economic data, optional) ────────
# Drives the macro-catalyst calendar (CPI, FOMC, NFP, GDP). Get a
# free key at https://fredaccount.stlouisfed.org/apikeys
# Empty disables the feed; the stock cycle falls back to whatever
# other catalyst sources are configured.
FRED_API_KEY=

# ── SEC EDGAR (free, no key — just identify yourself) ───────
# Required by the SEC: every request must carry a User-Agent with a
# real contact, e.g. "Your Name (your@email.com)". Empty disables
# the 8-K material-event catalyst stream.
EDGAR_USER_AGENT=

# ── Etherscan API (free, on-chain whale flows) ──────────────
# Get a free key at https://etherscan.io/myapikey (5 req/sec free
# tier). Drives the crypto-side whale-transfer signal source. Empty
# disables it cleanly.
ETHERSCAN_API_KEY=

# ── Halal screening cadence ─────────────────────────────────
# Hard TTL: ensure_cache refuses to refresh more often than this.
HALAL_CACHE_MAX_AGE_HOURS=6
# Soft threshold: refresh_if_stale fires a mid-cycle refresh past this age.
HALAL_MIDCYCLE_REFRESH_HOURS=4

# ── Dashboard control surface ───────────────────────────────
# Shared secret required on the X-Trader-Token header for any
# mutation endpoint. Empty disables mutations (read-only mode).
WEB_API_TOKEN=
# Whether destructive ops require X-Trader-Confirm: true. Disable
# in tests only; never in production.
WEB_REQUIRE_CONFIRMATION=true

# ── LLM ─────────────────────────────────────────────────────
# Provider: ollama | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:32b
OLLAMA_HOST=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Ordered fallback list, e.g. ["openai","anthropic"]. Empty = no fallbacks.
LLM_FALLBACK_PROVIDERS=[]
# Hard cap on cumulative LLM spend per UTC day, in USD. 0 disables enforcement.
# When tripped, engages the kill-switch — both bots refuse new entries.
LLM_DAILY_USD_CAP=0.0
# Adversarial co-bot — extra cheap critic call per cycle, downsizes/skips
# buys when a counter-thesis scores convincingly. Off by default.
LLM_ADVERSARIAL_ENABLED=false
# Number of additional ensemble LLM variants. 0 disables.
LLM_ENSEMBLE_SIZE=0
# Shadow strategy — runs a frozen-prompt strategy in parallel and
# tracks divergence in the equity curve. Off by default.
LLM_SHADOW_ENABLED=false
# Starting paper-cash for the shadow strategy's simulator.
LLM_SHADOW_STARTING_CASH=1000.0
# Empty = same as LLM_MODEL
OLLAMA_FALLBACK_MODEL=
OPENAI_FALLBACK_MODEL=gpt-4o-mini
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-20250514

# ── Stock Trading Parameters ────────────────────────────────
TRADING_INTERVAL_MINUTES=15
DAILY_RETURN_TARGET=0.01
MAX_POSITION_PCT=0.20
DAILY_LOSS_LIMIT=0.02
MAX_SIMULTANEOUS_POSITIONS=5

# ── Crypto Trading Parameters ───────────────────────────────
CRYPTO_TRADING_INTERVAL_SECONDS=60
CRYPTO_PAIRS=["BTCUSDT","ETHUSDT","SOLUSDT","ADAUSDT"]
CRYPTO_MAX_POSITION_PCT=0.25
CRYPTO_DAILY_LOSS_LIMIT=0.03
CRYPTO_DAILY_RETURN_TARGET=0.01
CRYPTO_MAX_SIMULTANEOUS_POSITIONS=4
# Min market cap (USD) for crypto halal screening
CRYPTO_MIN_MARKET_CAP=1000000000
CRYPTO_MAX_PAIRS_PER_CYCLE=10

# ── Portfolio-level risk (crypto) ───────────────────────────
# Max unrealized loss before blocking new entries
CRYPTO_MAX_PORTFOLIO_HEAT_PCT=0.05
# Max peak-to-trough drawdown before halting all trading
CRYPTO_MAX_DRAWDOWN_PCT=0.08
# Pearson threshold above which to shrink correlated positions
CRYPTO_HIGH_CORRELATION_THRESHOLD=0.7
# Size multiplier when correlated with an open position
CRYPTO_CORRELATION_REDUCTION_FACTOR=0.5
# ATR baseline for volatility-adjusted position sizing
CRYPTO_ATR_BASELINE=0.02

# ── Flat-market skip thresholds (crypto) ────────────────────
# Min 5m price change (%) to consider a market non-flat
CRYPTO_FLAT_PRICE_THRESHOLD=0.03
# RSI < this = non-flat (oversold)
CRYPTO_FLAT_RSI_LOWER=40.0
# RSI > this = non-flat (overbought)
CRYPTO_FLAT_RSI_UPPER=60.0
# Volume ratio above this = non-flat
CRYPTO_FLAT_VOL_THRESHOLD=1.2
# Max consecutive flat-market skips before forcing an LLM call
CRYPTO_MAX_CONSECUTIVE_FLAT_SKIPS=5

# ── Trailing stop / monitor (crypto) ────────────────────────
# % above entry to activate trailing stop
CRYPTO_TRAILING_STOP_ACTIVATION_PCT=0.005
# Trailing stop distance from high water mark
CRYPTO_TRAILING_STOP_DISTANCE_PCT=0.003
# Seconds between position monitor checks
CRYPTO_MONITOR_INTERVAL=2.0

# ── Per-pair circuit breaker (crypto) ───────────────────────
CRYPTO_CIRCUIT_BREAKER_THRESHOLD=5
CRYPTO_CIRCUIT_BREAKER_WINDOW=600
CRYPTO_CIRCUIT_BREAKER_COOLDOWN=1800

# ── LLM circuit breaker ─────────────────────────────────────
CRYPTO_LLM_FAILURE_THRESHOLD=5
CRYPTO_LLM_COOLDOWN_SECONDS=600

# ── Sentiment (optional) ────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
CRYPTOPANIC_API_KEY=
SENTIMENT_UPDATE_INTERVAL_SECONDS=300
SENTIMENT_USE_FINBERT=false

# ── ML Models (requires [ml] extra) ─────────────────────────
ML_ENABLED=false
# cpu | cuda | mps
ML_DEVICE=cpu
ML_MODELS_DIR=models

# ── Telegram Notifications (optional) ───────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Live-mode safeguards ────────────────────────────────────
# Must equal "I-UNDERSTAND-REAL-MONEY-YYYY-MM-DD" with today's date.
# Required to start when BINANCE_TESTNET=false or ALPACA_PAPER_TRADE=false.
LIVE_MODE_CONFIRMATION=
# Hard ceiling on account balance in live mode (USD)
MAX_ACCOUNT_BALANCE_USD=500.0
# Hard ceiling on a single order's notional in live mode (USD)
MAX_SINGLE_ORDER_USD=100.0
# Hard floor on daily_loss_limit in live mode (cannot be loosened)
LIVE_MODE_MAX_DAILY_LOSS_PCT=0.02

# ── Database ────────────────────────────────────────────────
DB_PATH=halal_trader.db
# Where daily gzipped SQLite backups land
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
# Weekly backups (Sundays) kept on top of the daily retention
BACKUP_WEEKLY_COUNT=12

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE_LEVEL=DEBUG
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
